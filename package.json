{
  "name": "codex-vaultwarden-bridge",
  "version": "0.1.0",
  "description": "A local Codex plugin for safely using Vaultwarden and Bitwarden CLI credentials.",
  "type": "module",
  "main": "mcp/server.mjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run check && npm test && npm run build"
  },
  "keywords": [
    "codex",
    "vaultwarden",
    "bitwarden",
    "mcp",
    "ssh",
    "secrets"
  ],
