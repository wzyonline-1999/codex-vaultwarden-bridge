{
  "mcpServers": {
    "vaultwarden-bridge": {
      "command": "node",
      "args": [
        "./mcp/server.mjs"
      ],
      "cwd": ".",
      "tool_timeout_sec": 120,
      "env": {
        "BW_SERVER": "https://vault.example.com",
        "VAULTWARDEN_BRIDGE_ALLOWED_TAG": "codex:ssh",
        "VAULTWARDEN_BRIDGE_REQUIRE_TAG": "true",
        "VAULTWARDEN_BRIDGE_DEFAULT_SSH_TTL_SECONDS": "28800"
      }
    }
  }
}
